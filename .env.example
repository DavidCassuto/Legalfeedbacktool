# Kopieer dit bestand naar .env voor lokale ontwikkeling
# Op Railway stel je deze in via het Variables-tabblad

# Flask
SECRET_KEY=vervang-dit-door-een-willekeurige-lange-string
FLASK_DEBUG=false

# Paden (Railway: zet op het volume mountpad, bijv. /data)
INSTANCE_PATH=/data

# AI-sleutels
ANTHROPIC_API_KEY=sk-ant-...
